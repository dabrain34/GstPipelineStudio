<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2022-2026 Stephane Cerveau <scerveau@igalia.com> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <provides>
    <id>org.freedesktop.dabrain34.GstPipelineStudio</id>
  </provides>
  <replaces>
    <id>org.freedesktop.dabrain34.GstPipelineStudio</id>
  </replaces>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name>GstPipelineStudio</name>
  <summary>Visualize your GStreamer pipelines</summary>
  <branding>
    <color type="primary" scheme_preference="light">#30D475</color>
    <color type="primary" scheme_preference="dark">#228B22</color>
  </branding>
  <description>
    <p>GstPipelineStudio aims to provide a graphical user interface to the GStreamer framework. From a first step in the framework with a simple pipeline to a complex pipeline debugging, the tool provides a friendly interface to add elements to a pipeline and debug it.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.freedesktop.org/dabrain34/GstPipelineStudio/-/raw/main/data/screenshots/gps_screenshot.png</image>
      <caption>Composition</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://dabrain34.pages.freedesktop.org/GstPipelineStudio</url>
  <url type="bugtracker">https://gitlab.freedesktop.org/dabrain34/GstPipelineStudio/issues</url>
  <url type="vcs-browser">https://gitlab.freedesktop.org/dabrain34/GstPipelineStudio</url>
  <categories>
    <category>Audio</category>
    <category>Video</category>
    <category>Development</category>
  </categories>
  <developer_name>Stéphane Cerveau</developer_name>
  <update_contact>scerveau@igalia.com</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
    <releases>
    <release version="@version@" date="@current_date@">
      <description>
        <p>New features, app identity update, and stability improvements</p>
        <p>New Features:</p>
        <ul>
          <li>Remote pipeline introspection</li>
          <li>Crash recovery dialog on startup</li>
          <li>DOT file loading with trait-based importer</li>
          <li>Auto-connect on node click</li>
          <li>Auto-arrange pipeline layout</li>
          <li>File selector for location property</li>
          <li>Logger copy to clipboard with multi-selection</li>
        </ul>
        <p>User Interface:</p>
        <ul>
          <li>Semi-transparent node backgrounds</li>
          <li>Dynamic node width in auto-arrange</li>
          <li>Improved node positioning and auto-scroll</li>
        </ul>
        <p>Build and Platforms:</p>
        <ul>
          <li>App ID renamed to dev.mooday.GstPipelineStudio</li>
          <li>GStreamer 1.28.0</li>
          <li>RPM packaging for Fedora</li>
          <li>Simplified version management</li>
        </ul>
        <p>Stability:</p>
        <ul>
          <li>Fix port counter decrement in remove_port</li>
          <li>Fix window visibility during splash screen</li>
          <li>Player position/duration precision improved</li>
        </ul>
        <p>Flathub:</p>
        <ul>
          <li>Add vcs-browser URL for linter compliance</li>
          <li>Shorten summary to comply with 35-character limit</li>
        </ul>
      </description>
    </release>
  </releases>
  <content_rating type="oars-1.1">
